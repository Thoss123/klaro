# ── Supabase ────────────────────────────────────────────────────────────────
# Schema/migrations: supabase/migrations/ — link + push:
#   npx supabase link --project-ref <project-ref>
#   npm run db:push
# Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>
#
# Auth redirects (Dashboard → Authentication → URL Configuration):
# - Site URL = deine LIVE-Domain (z. B. https://axantilo.com) — NICHT localhost
# - Redirect URLs (alle eintragen, je Zeile):
#     http://localhost:3000/**
#     https://axantilo.com/**
#     https://*.vercel.app/**          (Preview-Deployments)
# Ohne passende Redirect-URL fällt Supabase auf die Site URL zurück → Links zeigen auf localhost.
# Die App nutzt window.location.origin + /api/auth/callback (siehe AuthForm.tsx).
# Optional: only needed by server scripts that bypass auth/RLS (Settings → API → service_role).
# Keep this secret — never expose it to the browser.
# Required by `npm run index-knowledge` (writes to knowledge_base under RLS).
# The admin UI reindex route uses the logged-in user's session instead.
# SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── Admin ───────────────────────────────────────────────────────────────────
# Comma-separated allowlist for the /admin area (e.g. /admin/knowledge).
# Empty/unset = any logged-in user may access. Set to lock it down.
# ADMIN_EMAILS=you@example.com,partner@example.com

# ── AI provider ─────────────────────────────────────────────────────────────
AI_PROVIDER=mistral
# console.mistral.ai → API Keys (Chat, Voxtral /api/transcribe, OCR für Bilder)
MISTRAL_API_KEY=<mistral-key>
# Coach chat model. Default: mistral-medium-latest (Medium 3.5, agent-optimized).
# MISTRAL_CHAT_MODEL=mistral-medium-latest
# Optional fallbacks
# ANTHROPIC_API_KEY=<anthropic-key>
# GOOGLE_API_KEY=<google-ai-key>
# Web search — lets the coach look up tools/services it doesn't know & latest features.
# app.tavily.com → API Keys. Optional: without it, web_search fails open (model knowledge only).
TAVILY_API_KEY=<tavily-key>

# ── Phase 4 / Sprint 2 — n8n + credential encryption ────────────────────────
# Your self-hosted n8n instance. MUST end in /api/v1.
# Local dev with MOCK_N8N=true: leave as localhost.
# Live: the public HTTPS domain of your Hetzner instance, e.g. https://n8n.axantilo.com/api/v1
N8N_API_URL=http://localhost:5678/api/v1
# n8n UI → Settings → n8n API → "Create an API key"
N8N_API_KEY=<n8n-api-key>
# Public n8n URL (no /api/v1) — used for icons when live. Optional if bundled catalog is used.
# N8N_PUBLIC_URL=https://n8n.example.com
# Instance-level MCP — n8n UI → Settings → Instance-level MCP → Connection details
# N8N_MCP_URL=https://n8n.example.com/mcp-server/http
# N8N_MCP_TOKEN=<mcp-access-token>   # NOT the same as N8N_API_KEY
# Bundled node catalog versions (unpkg fallback when /types/nodes.json is not reachable)
# N8N_NODES_BASE_VERSION=2.15.1
# N8N_LANGCHAIN_VERSION=2.23.0
# true  = skip all real n8n calls (mock IDs) — use for local dev until the VPS is up.
# false = hit the real n8n instance (set on Vercel Preview/Prod once the VPS is live).
MOCK_N8N=true
# AES-256-GCM key for encrypting stored user credentials. Use a long random string in prod
# (e.g. `openssl rand -hex 32`). Changing it makes previously stored credentials unreadable.
ENCRYPTION_KEY=change-me-in-prod

# ── Google OAuth ─────────────────────────────────────────────────────────────
# console.cloud.google.com → APIs & Services → Credentials → OAuth 2.0 Client IDs
# Used by: Supabase Auth (Google sign-in) + n8n Google OAuth2-Credential default.
# In n8n docker-compose.yml also set:
#   N8N_OAUTH2_GOOGLE_CLIENT_ID: ${GOOGLE_CLIENT_ID}
#   N8N_OAUTH2_GOOGLE_CLIENT_SECRET: ${GOOGLE_CLIENT_SECRET}
# Callback URLs to register in Google Console (mehrere erlaubt — alle eintragen):
#   - n8n direkt:        https://n8n.axantilo.com/rest/oauth2-credential/callback
#   - Axantilo 3-Klick:  https://axantilo.com/api/oauth/callback/google
#   - Lokal (Dev):       http://localhost:3000/api/oauth/callback/google
GOOGLE_CLIENT_ID=<google-client-id>
GOOGLE_CLIENT_SECRET=<google-client-secret>

# ── In-App OAuth (3-Klick) — Google / Microsoft / Meta ───────────────────────
# Axantilos eigener OAuth-Flow (app/api/oauth/*). Der User klickt "Verbinden",
# loggt sich beim Anbieter ein, und wir legen das n8n-Credential automatisch an.
# Öffentliche App-URL — Basis für die Redirect-URIs oben. Lokal: http://localhost:3000
NEXT_PUBLIC_APP_URL=https://axantilo.com
#
# Microsoft Azure AD (Outlook / Teams / OneDrive):
#   portal.azure.com → App registrations → New registration
#   Redirect URI (Web): https://axantilo.com/api/oauth/callback/microsoft (+ localhost für Dev)
#   Client-Secret: Certificates & secrets → New client secret → Spalte "Value" (nicht die ID!)
MICROSOFT_CLIENT_ID=<application-client-id>
MICROSOFT_CLIENT_SECRET=<client-secret-value>
MICROSOFT_TENANT_ID=common
#
# Meta/Facebook (Pages + Instagram) — erst aktiv nach Business-Verifizierung:
#   developers.facebook.com → App (Business) → Facebook Login
#   Redirect URI: https://axantilo.com/api/oauth/callback/meta
# META_APP_ID=<app-id>
# META_APP_SECRET=<app-secret>

# ── Email — Resend ────────────────────────────────────────────────────────────
# resend.com → API Keys. All transactional emails via hello@axantilo.com.
# Supabase Auth emails also routed through Resend (Dashboard → Auth → SMTP Settings):
#   Host: smtp.resend.com  Port: 465  User: resend  Pass: <RESEND_API_KEY>
#   Sender: hello@axantilo.com
RESEND_API_KEY=<resend-api-key>

# ── Zentrale n8n-Credential-IDs (Shared Infra) ───────────────────────────────
# IDs der einmalig in n8n angelegten, zentral genutzten Credentials.
# n8n UI → Credentials → [Credential anlegen] → Numeric ID aus der URL kopieren.
#
# Resend SMTP (Send Email node):
#   n8n: Credential type = "SMTP", Host=smtp.resend.com Port=587 User=resend Pass=<RESEND_API_KEY>
#   Alle Mails gehen von hello@axantilo.com — kein Setup für Nutzer nötig.
N8N_CREDENTIAL_SMTP=<n8n-smtp-credential-id>
#
# Twilio (SMS / WhatsApp via Twilio):
#   n8n: Credential type = "Twilio API", Account SID + Auth Token aus console.twilio.com
N8N_CREDENTIAL_TWILIO=<n8n-twilio-credential-id>
#
# WhatsApp Business Cloud (Meta) — nur wenn du den nativen WA-Node statt Twilio nutzt:
# N8N_CREDENTIAL_WHATSAPP=<n8n-whatsapp-credential-id>

# ── Twilio ────────────────────────────────────────────────────────────────────
# console.twilio.com → Account → API keys & tokens
TWILIO_ACCOUNT_SID=<twilio-account-sid>
TWILIO_AUTH_TOKEN=<twilio-auth-token>
# Deine zentrale Twilio-Nummer (für SMS + WhatsApp-Sandbox):
TWILIO_FROM_NUMBER=+1234567890
