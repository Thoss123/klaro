{
  "name": "AXANTILO: E-Mail Triage & Entwurf",
  "nodes": [
    {
      "name": "Neue E-Mail",
      "type": "{{TRIGGER_NODE}}",
      "typeVersion": 1,
      "position": [
        0,
        300
      ],
      "parameters": {
        "pollTimes": {
          "item": [
            {
              "mode": "everyMinute"
            }
          ]
        },
        "simple": false,
        "filters": {},
        "options": {}
      }
    },
    {
      "name": "KI: Kategorisieren",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        300
      ],
      "parameters": {
        "method": "POST",
        "url": "{{APP_BASE_URL}}/api/agent/llm",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ project_id: '{{PROJECT_ID}}', prompt_key: 'email/classify', user: 'Betreff: ' + ($('Neue E-Mail').item.json.subject || '') + '\\n\\n' + ($('Neue E-Mail').item.json.textPlain || $('Neue E-Mail').item.json.snippet || '') }) }}",
        "options": {}
      }
    },
    {
      "name": "Kategorie parsen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        300
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const PROMPT_BY_CATEGORY = {\n  lead_inquiry: 'email/draft_lead_inquiry',\n  scheduling: 'email/draft_scheduling',\n  support_faq: 'email/draft_support_faq',\n  other: 'email/draft_other',\n};\nreturn $input.all().map(item => {\n  let category = 'other';\n  try {\n    const parsed = JSON.parse(item.json.text);\n    if (parsed && parsed.category && (PROMPT_BY_CATEGORY[parsed.category] || parsed.category === 'billing' || parsed.category === 'spam_marketing')) {\n      category = parsed.category;\n    }\n  } catch (e) { /* ungültiges LLM-JSON -> sicherer Fallback \"other\" */ }\n  return { json: { category, prompt_key: PROMPT_BY_CATEGORY[category] || null } };\n});"
      }
    },
    {
      "name": "Switch",
      "type": "n8n-nodes-base.switch",
      "typeVersion": 3.4,
      "position": [
        720,
        300
      ],
      "parameters": {
        "mode": "rules",
        "rules": {
          "values": [
            {
              "outputKey": "lead_inquiry",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "lead_inquiry"
                  }
                ]
              }
            },
            {
              "outputKey": "scheduling",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "scheduling"
                  }
                ]
              }
            },
            {
              "outputKey": "support_faq",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "support_faq"
                  }
                ]
              }
            },
            {
              "outputKey": "billing",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "billing"
                  }
                ]
              }
            },
            {
              "outputKey": "spam_marketing",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "spam_marketing"
                  }
                ]
              }
            },
            {
              "outputKey": "other",
              "renameOutput": true,
              "conditions": {
                "combinator": "and",
                "options": {
                  "caseSensitive": false,
                  "leftValue": "",
                  "typeValidation": "strict"
                },
                "conditions": [
                  {
                    "leftValue": "={{ $json.category }}",
                    "operator": {
                      "type": "string",
                      "operation": "equals"
                    },
                    "rightValue": "other"
                  }
                ]
              }
            }
          ]
        },
        "options": {
          "fallbackOutput": "none"
        }
      }
    },
    {
      "name": "KI: Entwurf schreiben",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        980,
        220
      ],
      "parameters": {
        "method": "POST",
        "url": "{{APP_BASE_URL}}/api/agent/llm",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ project_id: '{{PROJECT_ID}}', prompt_key: $json.prompt_key, persona_path: '{{PERSONA_PATH}}', user: 'Betreff: ' + ($('Neue E-Mail').item.json.subject || '') + '\\nVon: ' + ($('Neue E-Mail').item.json.from || '') + '\\n\\n' + ($('Neue E-Mail').item.json.textPlain || $('Neue E-Mail').item.json.snippet || '') }) }}",
        "options": {}
      }
    },
    {
      "name": "Freigabe anlegen",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1220,
        220
      ],
      "parameters": {
        "method": "POST",
        "url": "{{APP_BASE_URL}}/api/agent/pending",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ project_id: '{{PROJECT_ID}}', contact: 'whatsapp:{{OWNER_WHATSAPP}}', payload: { draft: $json.text, first_draft: $json.text, feedback_log: [], category: $('Kategorie parsen').item.json.category, original_email: ($('Neue E-Mail').item.json.textPlain || $('Neue E-Mail').item.json.snippet || ''), send_target: ($('Neue E-Mail').item.json.from || ''), subject: ($('Neue E-Mail').item.json.subject || ''), provider: 'gmail', persona: '{{PERSONA_PATH}}' } }) }}",
        "options": {}
      }
    },
    {
      "name": "WhatsApp: Entwurf zur Freigabe",
      "type": "n8n-nodes-base.twilio",
      "typeVersion": 1,
      "position": [
        1460,
        220
      ],
      "parameters": {
        "from": "{{TWILIO_WHATSAPP_FROM}}",
        "to": "{{OWNER_WHATSAPP}}",
        "toWhatsapp": true,
        "message": "=📧 Neuer Entwurf ({{ $('Kategorie parsen').item.json.category }}) für: {{ $('Neue E-Mail').item.json.from }}\nBetreff: {{ $('Neue E-Mail').item.json.subject }}\n\n{{ $('KI: Entwurf schreiben').item.json.text }}\n\n— Antworte SENDEN zum Abschicken, oder schreib, was geändert werden soll.",
        "options": {}
      }
    },
    {
      "name": "Kein Entwurf nötig",
      "type": "n8n-nodes-base.noOp",
      "typeVersion": 1,
