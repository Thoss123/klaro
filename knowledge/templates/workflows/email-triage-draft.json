    {
      "name": "Revisions-Kontext bauen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        1376
      ],
      "parameters": {
        "jsCode": "// Pending-Zeile (GET /api/agent/pending) + Webhook-Body zu einem kompakten Kontext mergen.\nconst hook = $('Versand-Webhook').item.json.body || {};\nconst action = $json.action || $json || {};\nconst payload = action.payload || {};\nconst feedback = Array.isArray(payload.feedback_log) ? payload.feedback_log : [];\nconst texts = feedback.map(f => (f && typeof f.text === 'string') ? f.text : '').filter(Boolean);\nreturn [{ json: {\n  pending_id: action.id || hook.pending_action_id || '',\n  subject: payload.subject || '',\n  mail_ref: payload.mail_ref || '',\n  prev_draft: payload.draft || '',\n  feedback_all: texts.join('\\n- ') || '(kein Feedback-Text uebermittelt)',\n} }];"
      }
    },
