    {
      "name": "Kalender-Kontext bauen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        192
      ],
      "parameters": {
        "jsCode": "const events = $input.all().map(i => i.json).filter(e => e && (e.start || e.summary));\nlet kalender_kontext;\nif (!events.length) {\n  kalender_kontext = 'Kein Kalender-Zugriff oder keine Termine in den naechsten 7 Tagen gefunden — schlage KEINE konkreten Slots vor, sondern frage nach 2-3 Wunschterminen.';\n} else {\n  kalender_kontext = 'Belegte Termine der naechsten 7 Tage (heute ist ' + new Date().toISOString().slice(0, 10) + '). Schlage 2-3 freie Fenster innerhalb der Oeffnungszeiten vor, die NICHT kollidieren:\n'\n    + events.map(e => '- ' + (e.start?.dateTime || e.start?.date || '?') + ' bis ' + (e.end?.dateTime || e.end?.date || '?') + ': ' + (e.summary || 'belegt')).join('\n');\n}\nreturn [{ json: { kalender_kontext } }];"
      }
    },
