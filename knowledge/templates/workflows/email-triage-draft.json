    {
      "name": "KI: Kategorisieren",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -40,
        460
      ],
      "parameters": {
        "method": "POST",
        "url": "{{APP_BASE_URL}}/api/agent/llm",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ project_id: '{{PROJECT_ID}}', prompt_key: 'email/classify', user: 'Betreff: ' + ($('Neue E-Mail').item.json.subject || '') + '\\nVon: ' + ($('Neue E-Mail').item.json.from || '') + '\\n\\n' + ($('Neue E-Mail').item.json.textPlain || $('Neue E-Mail').item.json.snippet || '') }) }}",
        "options": {}
      }
    },
    {
      "name": "Kategorie parsen",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        180,
        460
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const VALID = [\"lead_inquiry\",\"scheduling\",\"support_faq\",\"vendor_billing\",\"system_alerts\",\"newsletters\",\"spam_marketing\",\"other\"];\nconst PROMPT_BY_CATEGORY = {\n  lead_inquiry: 'email/draft_lead_inquiry',\n  support_faq: 'email/draft_support_faq',\n  other: 'email/draft_other',\n};\nreturn $input.all().map(item => {\n  let category = 'other', urgency = 'medium', reason = '';\n  try {\n    const parsed = JSON.parse(item.json.text);\n    if (parsed && VALID.includes(parsed.category)) category = parsed.category;\n    if (['low','medium','high'].includes(parsed?.urgency)) urgency = parsed.urgency;\n    if (typeof parsed?.reason === 'string') reason = parsed.reason;\n  } catch (e) { /* ungültiges LLM-JSON -> sicherer Fallback \"other\" */ }\n  return { json: { category, urgency, reason, prompt_key: PROMPT_BY_CATEGORY[category] || null } };\n});"
      }
    },
